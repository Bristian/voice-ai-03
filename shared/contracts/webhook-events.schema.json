{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://car-dealership-voice-ai/contracts/webhook-events.schema.json",
  "title": "VonageWebhookEvents",
  "description": "Payload shapes for Vonage webhook callbacks to echokit-server.",
  "type": "object",
  "$defs": {
    "AnswerWebhookRequest": {
      "type": "object",
      "description": "POST /webhooks/answer — Vonage calls this when the forwarded call arrives.",
      "required": ["uuid", "from", "to"],
      "additionalProperties": true,
      "properties": {
        "uuid": {
          "type": "string",
          "description": "Call UUID (becomes our call_uuid everywhere)."
        },
        "conversation_uuid": { "type": "string" },
        "from": {
          "type": "string",
          "description": "Caller's E.164 number."
        },
        "to": {
          "type": "string",
          "description": "DID the caller dialed (the dealership number)."
        },
        "region_url": { "type": "string" },
        "custom_data": { "type": "object" }
      }
    },
    "EventWebhookRequest": {
      "type": "object",
      "description": "POST /webhooks/events — Vonage call state transitions.",
      "required": ["status", "uuid"],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "started",
            "ringing",
            "answered",
            "busy",
            "cancelled",
            "failed",
            "rejected",
            "timeout",
            "unanswered",
            "completed",
            "machine",
            "human"
          ]
        },
        "uuid": { "type": "string" },
        "conversation_uuid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "direction": {
          "type": "string",
          "enum": ["inbound", "outbound"]
        },
        "duration": {
          "type": ["string", "integer"],
          "description": "Duration in seconds. Present on `completed`."
        },
        "price": { "type": "string" },
        "rate": { "type": "string" },
        "network": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "reason_code": { "type": ["string", "integer"] },
        "reason": { "type": "string" }
      }
    },
    "NCCO": {
      "type": "array",
      "description": "Nexmo Call Control Object — returned as the response body to /webhooks/answer.",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/TalkAction" },
          { "$ref": "#/$defs/ConnectAction" },
          { "$ref": "#/$defs/StreamAction" },
          { "$ref": "#/$defs/RecordAction" },
          { "$ref": "#/$defs/InputAction" }
        ]
      }
    },
    "TalkAction": {
      "type": "object",
      "required": ["action", "text"],
      "properties": {
        "action": { "const": "talk" },
        "text": { "type": "string" },
        "bargeIn": { "type": "boolean", "default": false },
        "loop": { "type": "integer", "default": 1 },
        "level": { "type": "number" },
        "language": { "type": "string" },
        "style": { "type": "integer" }
      }
    },
    "ConnectAction": {
      "type": "object",
      "required": ["action", "endpoint"],
      "properties": {
        "action": { "const": "connect" },
        "endpoint": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "required": ["type", "uri"],
                "properties": {
                  "type": { "const": "websocket" },
                  "uri": { "type": "string" },
                  "content-type": { "type": "string" },
                  "headers": { "type": "object" }
                }
              },
              {
                "type": "object",
                "required": ["type", "number"],
                "properties": {
                  "type": { "const": "phone" },
                  "number": { "type": "string" }
                }
              }
            ]
          }
        },
        "timeout": { "type": "integer" },
        "from": { "type": "string" }
      }
    },
    "StreamAction": {
      "type": "object",
      "required": ["action", "streamUrl"],
      "properties": {
        "action": { "const": "stream" },
        "streamUrl": { "type": "array", "items": { "type": "string" } },
        "bargeIn": { "type": "boolean" },
        "loop": { "type": "integer" },
        "level": { "type": "number" }
      }
    },
    "RecordAction": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "const": "record" },
        "eventUrl": { "type": "array", "items": { "type": "string" } },
        "format": { "type": "string", "enum": ["mp3", "wav", "ogg"] },
        "endOnSilence": { "type": "integer" },
        "endOnKey": { "type": "string" },
        "timeOut": { "type": "integer" },
        "beepStart": { "type": "boolean" }
      }
    },
    "InputAction": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "const": "input" },
        "type": {
          "type": "array",
          "items": { "type": "string", "enum": ["dtmf", "speech"] }
        },
        "dtmf": { "type": "object" },
        "eventUrl": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
