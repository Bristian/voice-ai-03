{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://car-dealership-voice-ai/contracts/agent-turn.schema.json",
  "title": "AgentTurn",
  "description": "Request and response types for POST /v1/agent/turn — the primary agent-api endpoint called by echokit-server on every final STT transcript.",
  "type": "object",
  "$defs": {
    "AgentTurnRequest": {
      "type": "object",
      "required": ["call_uuid", "transcript", "caller_phone_hash"],
      "additionalProperties": false,
      "properties": {
        "call_uuid": { "type": "string", "minLength": 1 },
        "transcript": {
          "type": "string",
          "description": "Final (not partial) STT transcript for the caller's most recent utterance."
        },
        "caller_phone_hash": { "type": "string" },
        "session_entities": {
          "$ref": "session.schema.json#/$defs/SessionEntities"
        },
        "conversation_history": {
          "type": "array",
          "description": "Prior turns. Last 6 are passed to the synthesis LLM.",
          "items": { "$ref": "session.schema.json#/$defs/ConversationTurn" },
          "default": []
        },
        "stt_confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "AgentTurnResponse": {
      "type": "object",
      "required": ["response_text", "intent", "action", "latency_ms"],
      "additionalProperties": false,
      "properties": {
        "response_text": {
          "type": "string",
          "description": "Voice-first reply. ≤ 50 words, no markdown."
        },
        "intent": {
          "type": "string",
          "enum": [
            "vehicle_search",
            "pricing_query",
            "availability_check",
            "financing_inquiry",
            "dealership_info",
            "appointment_request",
            "human_transfer"
          ]
        },
        "intent_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "updated_entities": {
          "$ref": "session.schema.json#/$defs/SessionEntities"
        },
        "results": {
          "type": "object",
          "properties": {
            "rag_chunks": {
              "type": "array",
              "items": { "$ref": "#/$defs/RagChunk" },
              "default": []
            },
            "vehicles": {
              "type": "array",
              "items": { "$ref": "vehicle.schema.json" },
              "default": []
            }
          }
        },
        "action": {
          "type": "string",
          "enum": ["respond", "transfer", "collect_lead", "end_call"]
        },
        "transfer_to": {
          "type": ["string", "null"],
          "description": "E.164 phone number when action == 'transfer'.",
          "pattern": "^\\+[1-9][0-9]{7,14}$"
        },
        "latency_ms": {
          "$ref": "#/$defs/LatencyMetrics"
        }
      }
    },
    "RagChunk": {
      "type": "object",
      "required": ["source", "content", "score"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": ["string", "null"] },
        "source": {
          "type": "string",
          "enum": ["faq", "policy", "promo", "financing", "service"]
        },
        "content": { "type": "string" },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Post-rerank relevance score. < 0.75 triggers hallucination guard."
        }
      }
    },
    "LatencyMetrics": {
      "type": "object",
      "description": "Per-stage latency in milliseconds. Stored in logs for observability.",
      "additionalProperties": false,
      "properties": {
        "intent_ms": { "type": "number", "minimum": 0 },
        "rag_ms": { "type": "number", "minimum": 0 },
        "sql_ms": { "type": "number", "minimum": 0 },
        "synthesis_ms": { "type": "number", "minimum": 0 },
        "total_ms": { "type": "number", "minimum": 0 }
      }
    }
  }
}
